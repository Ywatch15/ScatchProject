<%- include('./partials/header') %>
<div class="w-full h-screen flex items-start px-20 py-20 gap-10">
  <div class="w-[40%] rounded-md overflow-hidden">
    <h2 class="text-2xl mb-4">Your Cart</h2>
    <% if (Array.isArray(cart) && cart.length) { %> <%
    cart.forEach(function(item){ %> <% var product = item.product; var qty =
    item.qty; %>
    <div class="mb-6 border rounded p-4">
      <div class="flex gap-4 items-center">
        <% if (product) { %> <% var bg = product.bgcolor ? product.bgcolor :
        '#f3f4f6'; %> <% var panel = product.panelcolor ? product.panelcolor :
        '#ffffff'; %> <% var textcolor = product.textcolor ? product.textcolor :
        '#111827'; %>
        <div
          class="w-32 h-32 flex items-center justify-center"
          style="background-color: <%= bg %>"
        >
          <% if (product.imageUrl) { %>
          <img
            class="max-h-28"
            src="<%= product.imageUrl %>"
            alt="<%= product.name %>"
          />
          <% } else if (product.image) { %>
          <img
            class="max-h-28"
            src="data:image/jpeg;base64,<%= product.image.toString('base64') %>"
            alt="<%= product.name %>"
          />
          <% } else { %>
          <img
            class="max-h-28"
            src="/images/placeholder.png"
            alt="placeholder"
          />
          <% } %>
        </div>
        <div class="flex-1">
          <h3 class="text-lg font-semibold"><%= product.name %></h3>
          <div class="text-sm text-gray-600">Price: ₹ <%= product.price %></div>
          <div class="text-sm text-gray-600">
            Discount: ₹ <%= Number(product.discount || 0) %>
          </div>
          <div class="mt-3 flex items-center gap-2">
            <a
              href="/cart/decrement/<%= product._id %>"
              class="px-3 py-1 bg-gray-200 rounded"
              >-</a
            >
            <div class="px-3 py-1 bg-white border rounded">
              <%= qty.toString().padStart(2,'0') %>
            </div>
            <a
              href="/cart/increment/<%= product._id %>"
              class="px-3 py-1 bg-gray-200 rounded"
              >+</a
            >
          </div>
        </div>
        <div class="text-right">
          <div class="text-lg font-semibold">
            ₹ <%= (Number(product.price || 0) - Number(product.discount || 0)) *
            qty %>
          </div>
        </div>
        <% } else { %>
        <div class="flex-1">
          <h3 class="text-lg font-semibold">Product unavailable</h3>
          <div class="text-sm text-gray-600">
            This product has been removed.
          </div>
        </div>
        <% } %>
      </div>
    </div>
    <% }) %> <% } else { %>
    <div>Your cart is empty.</div>
    <% } %>
  </div>
  <div class="w-[60%]">
    <h3 class="text-xl">Price Breakdown</h3>
    <div class="px-10 mt-5">
      <div class="flex mt-2">
        <h4 class="w-1/3">Total MRP</h4>
        <% var totalMRP = (Array.isArray(cart) ? cart.reduce((s,it)=> s +
        (Number((it.product && it.product.price) || 0) * it.qty), 0) : 0); %>
        <h4>₹ <%= totalMRP %></h4>
      </div>
      <div class="flex mt-2">
        <h4 class="w-1/3">Discount on MRP</h4>
        <% var totalDiscount = (Array.isArray(cart) ? cart.reduce((s,it)=> s +
        (Number((it.product && it.product.discount) || 0) * it.qty), 0) : 0); %>
        <h4>₹ <%= totalDiscount %></h4>
      </div>
      <div class="flex mt-2">
        <h4 class="w-1/3">Platform Fee</h4>
        <h4>₹ 20</h4>
      </div>
      <div class="flex mt-2">
        <h4 class="w-1/3">Shipping Fee</h4>
        <h4>FREE</h4>
      </div>
    </div>
    <div class="w-full h-[1px] bg-black mt-10"></div>
    <div class="flex mt-5">
      <h3 class="w-1/3 text-xl">Total Amount</h3>
      <h3 class="font-semibold text-xl text-green-600">₹ <%= bill %></h3>
    </div>
    <form action="" method="post"></form>
  </div>
</div>
<%- include('./partials/footer') %>
